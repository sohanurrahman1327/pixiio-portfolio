# Gmail SMTP — used by /api/contact and /api/booking
# 1. Enable 2-Step Verification on agency.pixiio@gmail.com
# 2. Create an App Password: https://myaccount.google.com/apppasswords
# 3. Copy the 16-character password below (spaces optional)
#
# IMPORTANT (Vercel / production):
# Add GMAIL_USER + GMAIL_APP_PASSWORD in the Vercel project Environment Variables
# for Production (and Preview), then Redeploy. Without that, the live contact
# form returns 503 and falls back to mailto.
#
# Booking admin dashboard
# BOOKING_ADMIN_SECRET=@gency.pixiio215
#
# Optional: force a Google Authenticator secret (otherwise first login
# generates + stores one in Redis / local data/admin-totp.json)
# BOOKING_ADMIN_TOTP_SECRET=BASE32SECRETFROMGOOGLEAUTH
GMAIL_USER=agency.pixiio@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password_here

# Google Meet — create a permanent room at https://meet.google.com/new
# then paste the link here (shown in booking modal + confirmation emails)
NEXT_PUBLIC_GOOGLE_MEET_LINK=https://meet.google.com/your-meeting-code

# ── SEO ──────────────────────────────────────────────────────────────
# REQUIRED in production: the canonical public URL of the site (no
# trailing slash). Used to build the sitemap, robots.txt, canonical
# tags, and Open Graph URLs. Without this, those all fall back to the
# Vercel preview URL or localhost, which breaks SEO on the live site.
NEXT_PUBLIC_SITE_URL=https://pixiio.com

# Optional: paste the verification code Google Search Console gives you
# under Settings > Ownership verification > HTML tag (just the content
# value, not the full <meta> tag). Leave blank if you verify via DNS
# or Google Analytics instead.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# ── Tawk.to live chat ────────────────────────────────────────────────
# From your Tawk.to dashboard: Administration > Channels > Chat Widget,
# or straight from the embed snippet URL:
# https://embed.tawk.to/<PROPERTY_ID>/<WIDGET_ID>
# Leave either blank to disable the widget.
NEXT_PUBLIC_TAWK_PROPERTY_ID=
NEXT_PUBLIC_TAWK_WIDGET_ID=
